      "hustle": {
        "title": "How to play Hustle",
        "steps": [
          { "title": "Roll & move", "body": "Race around the 60-square Naija board. Land on shops, scams, blessings and trouble." },
          { "title": "Hustle cards", "body": "Pick cards every few squares. Play them to push, protect or scam your rivals." },
          { "title": "Japa to win", "body": "Reach UK, Canada or US exits with the right cash and documents — first one to japa wins." }
        ]
      },
      "word-wahala": {
        "title": "How to play Word Wahala",
        "steps": [
          { "title": "Place letters", "body": "Build words on the board, Scrabble-style. Standard, Pidgin and Naija slang all score." },
          { "title": "Bonus tiles", "body": "Land on coloured squares for double or triple letter and word scores." },
          { "title": "Highest score wins", "body": "Game ends when the bag is empty or after 6 consecutive passes." }
        ]
      },
      "landlord": {
        "title": "How to play Oga Landlord",
        "steps": [
          { "title": "Buy properties", "body": "Roll the dice, land on streets and snap them up. Collect colour sets to build." },
          { "title": "Build & charge rent", "body": "Houses and hotels make rent painful. Trade with rivals to lock down a colour group." },
          { "title": "Last one standing", "body": "Bankrupt your rivals to take the crown." }
        ]
      },
      "connect-4": {
        "title": "How to play Connect 4 (tag-team)",
        "steps": [
          { "title": "Two teams", "body": "Auto-balanced into Team Red and Team Yellow. You take alternating turns within your team." },
          { "title": "Drop a disc", "body": "Tap a column on your turn. Your team's colour drops to the lowest empty cell." },
          { "title": "Connect four", "body": "First team to line up four discs (any direction) wins the match." }
        ]
      },
      "ettt": {
        "title": "How to play Endless Tic Tac Toe",
        "steps": [
          { "title": "Two teams", "body": "Team X and Team O alternate placing marks. Auto-balanced when the host starts." },
          { "title": "3 marks per team", "body": "Each team can only have 3 marks on the board. Place a 4th and your team's oldest mark vanishes." },
          { "title": "Line up 3", "body": "First team to get three of their own marks in a line wins." }
        ]
      }
    }
  },

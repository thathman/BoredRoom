# Colyseus realtime server (WebSocket URL)
VITE_COLYSEUS_URL="ws://localhost:2567"

# Server-side Supabase (NEVER expose the service-role key to the frontend).
# Used by the Colyseus server for HouseSession persistence. Set in the deploy env / docker-compose.
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
GAME_ADMIN_TOKEN="generate-a-long-random-admin-token"
GAME_ADMIN_ORIGINS="https://party.hendrix.com.ng"

# Optional non-voice AI through DeepSeek. Gameplay remains available without it.
DEEPSEEK_API_KEY=""
DEEPSEEK_MODEL="deepseek-v4-flash"
DEEPSEEK_BASE_URL="https://api.deepseek.com"

# Dynamic Naija TTS (YarnGPT) — server-side only, never exposed to the frontend
TTS_BASE_URL=
TTS_API_KEY=
TTS_VOICE=
TTS_VOICES="Idera,Tayo,Chinenye,Nonso,Mary,Femi"

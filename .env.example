# Supabase (publishable/anon key — safe to expose to the frontend)
VITE_SUPABASE_PROJECT_ID="your-project-ref"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-publishable-key"
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"

# Colyseus realtime server (WebSocket URL)
VITE_COLYSEUS_URL="ws://localhost:2567"

# Server-side Supabase (NEVER expose the service-role key to the frontend).
# Used by the Colyseus server for HouseSession persistence. Set in the deploy env / docker-compose.
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
PACK_ADMIN_TOKEN="generate-a-long-random-admin-token"

# logo.dev publishable token for Logo Guesser (https://logo.dev)
VITE_LOGO_DEV_TOKEN="your-logo-dev-publishable-token"
